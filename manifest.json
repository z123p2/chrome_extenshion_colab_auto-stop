{
  "manifest_version": 3,
  "name": "Colab Auto-Disconnect",
  "version": "1.0",
  "description": "Автоматически отключает среду выполнения Colab после завершения всех ячеек",
  "host_permissions": ["https://colab.research.google.com/*"],
  "content_scripts": [
    {
      "matches": ["https://colab.research.google.com/*"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
